# Copy to .env and fill in your values
# Only AFM_PG_DSN is required

AFM_PG_DSN=postgresql://user:pass@localhost:5432/afm

# Embedding model (leave empty to disable semantic features)
AFM_EMBEDDING_MODEL_PATH='BAAI/bge-m3'

# LLM backend
AFM_LLM_BACKEND=ollama
AFM_LLM_MODEL=qwen2.5-coder:14b
AFM_LLM_BASE_URL=http://localhost:11434

# Cluster auto-rebuild (Gap 1 fix)
AFM_CLUSTER_REBUILD_EVERY_N=500
AFM_CLUSTER_K_MIN=8
AFM_CLUSTER_K_MAX=0

# API
AFM_API_HOST=0.0.0.0
AFM_API_PORT=8000
AFM_API_TOKEN=

# Ingestion
AFM_STORE_RAW_ROW_JSON=false
AFM_PARSER_VERSION=v2.1-fixed
AFM_MAX_META_LOOKBACK_ROWS=80
