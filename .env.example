
# Core database
AFM_PG_DSN=postgresql://afmuser:afmpass@pgvector:5432/afmdb
# Alternative (local dev):
# AFM_PG_DSN=postgresql+psycopg2://postgres:1234@localhost:5432/afmdb_turbo

# Optional: SQLAlchemy async URL
# DATABASE_URL=postgresql+asyncpg://afm_user:123!@localhost:5432/afmdb?ssl=prefer

# Embeddings
AFM_EMBEDDING_PROVIDER=ollama
AFM_EMBEDDING_MODEL=bge-m3
AFM_EMBEDDING_BASE_URL=http://localhost:11434
AFM_EMBEDDING_TIMEOUT_S=0
# Set timeout to 0 for no limit.
AFM_EMBEDDING_THRESHOLD=0.85
AFM_FORMAT_SIMILARITY_THRESHOLD=0.92
AFM_STORE_RAW_ROW_JSON=false

# If you want local sentence-transformers instead:
# AFM_EMBEDDING_PROVIDER=sentence-transformers
# AFM_EMBEDDING_MODEL=models/bge-m3


# Parser
AFM_PARSER_VERSION=v2.0-enterprise
AFM_MAX_META_LOOKBACK_ROWS=80


# Ollama / NL2SQL
AFM_LLM_BASE_URL=http://localhost:11434
AFM_LLM_MODEL=qwen2.5-coder:7b-instruct-q4_k_m
# For Gemini test mode, set AFM_LLM_MODEL=gemini (or gemini:<model>)
# and export GEMINI_API_KEY in your shell (do not put it in .env).
AFM_LLM_TIMEOUT_S=0
# Set timeout to 0 for no limit.
AFM_LLM_MAX_NEW_TOKENS=512

# Optional: Intent LLM model
AFM_INTENT_LLM_MODEL=qwen2.5-coder:7b-instruct-q4_k_m

# Admin seed user (for initial login)
ADMIN_EMAIL=myadmin@local
ADMIN_PASSWORD=123123

# SMTP (email) settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=True
SMTP_USE_SSL=False
EMAIL_CODE_TTL_MINUTES=10

# Session & JWT
SESSION_SECRET=dev-session-secret
JWT_SECRET=dev-secret
JWT_ALG=HS256

# DB Pooling (for production tuning)
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=True

# Feature flags
ENABLE_SEED=True
NL2SQL_SAVE_HISTORY=True
NL2SQL_ADMIN_ONLY=True

JWT_SECRET = "dev-secret"
JWT_ALG = "HS256"
